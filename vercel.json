{
    "cleanUrls": true,
    "rewrites": [
        { "source": "/_expo/(.*)", "destination": "/app/_expo/$1" },
        { "source": "/assets/(.*)", "destination": "/app/assets/$1" },
        { "source": "/static/(.*)", "destination": "/app/static/$1" },
        { "source": "/descargar", "destination": "/descargar.html" },
        { "source": "/(.*)", "destination": "/app/index.html" }
    ],
    "redirects": [
        {
            "source": "/www/(.*)",
            "destination": "https://veoveo.dripdev.dev/$1",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/(.+\\.apk)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/.well-known/(.*)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/json"
                }
            ]
        }
    ]
}