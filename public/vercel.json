{
    "rewrites": [
        { "source": "/descargar", "destination": "/descargar.html" },
        { "source": "/(.*)", "destination": "/index.html" }
    ],
    "redirects": [
        {
            "source": "/www/(.*)",
            "destination": "https://veoveo.dripdev.dev/$1",
            "permanent": true
        },
        {
            "source": "/veoveo-latest.apk",
            "destination": "https://github.com/roblesgg/VeoVeo/releases/latest/download/veoveo-latest.apk",
            "permanent": false
        },
        {
            "source": "/apk",
            "destination": "https://github.com/roblesgg/VeoVeo/releases/latest/download/veoveo-latest.apk",
            "permanent": false
        }
    ],
    "headers": [
        {
            "source": "/.well-known/(.*)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/json"
                }
            ]
        }
    ]
}
